{
  "manifest_version": 3,
  "name": "TypeShift",
  "version": "1.2.0",
  "description": "Cleanly shift the typography of any website while protecting native icon fonts.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}